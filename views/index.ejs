<!DOCTYPE html>
<html>
  <head>
    <title>Assignment2: Secure DLT inventory management</title>
  </head>
  <body>
    <% if (!step || step === 'form') { %>
      <h2>Submitting a new record:</h2>
      <form action="/submit-record" method="POST">
        <div>
          <label>Origin Inventory Node</label>
          <select name="originNode" required>
            <option value="A">Inventory A</option>
            <option value="B">Inventory B</option>
            <option value="C">Inventory C</option>
            <option value="D">Inventory D</option>
          </select>
        </div>
        <div>
          <label>ItemID</label>
          <input type="number" name="ItemID" required>
        </div>

      <div>
        <label>ItemQty</label>
        <input type="number" name="ItemQty" required>
      </div>

      <div>
        <label>ItemPrice</label>
        <input type="number" name="ItemPrice" required>
      </div>

      <div>
        <label>Location</label>
        <input type="text" name="location" required>
      </div>

        <button type="submit">Submit Record</button>
      </form>

      <h2>Retrieve data by Record ID</h2>
      <form action="/query-record" method="POST">
        <div>
          <label>Record ID</label>
          <input type="text" name="recordID" placeholder="Item ID" required>
        </div>
        <button type="submit">Search Record</button>
      </form>

      <% if (typeof message !== 'undefined' && message) { %>
        <p><strong><%= message %></strong></p>
      <% } %>
    <% } %>

    <% if (step === 'search') { %>
      <h1>Record Lookup Demo</h1>
      <p><strong>Search Record ID:</strong> <%= recordId %></p>
      <p><strong>Status:</strong> <%= message %></p>

      <% if (!record) { %>
        <p>Record not found. Try another ID or return to the form.</p>
        <a href="/">Back to Form</a>
      <% } else { %>
        <% if (!queryStage || queryStage === 'search') { %>
          <p>Record found. Proceed through the multi-signature verification steps below.</p>
          <form action="/query-record" method="POST">
            <input type="hidden" name="recordID" value="<%= recordId %>">
            <input type="hidden" name="stage" value="generate">
            <button type="submit">Step 1: Generate PKG key pair</button>
          </form>
        <% } else if (queryStage === 'generate') { %>
          <h2>Step 1: PKG Key Generation</h2>
          <p><strong>PKG public key:</strong> (<%= multiSig.pkgParams.e %>, <%= multiSig.pkgParams.n %>)</p>
          <p><strong>PKG private key:</strong> (<%= multiSig.pkgParams.d %>, <%= multiSig.pkgParams.n %>)</p>

          <h3>Identity-based secret keys</h3>
          <ul>
            <% Object.values(multiSig.identitySecrets).forEach(secret => { %>
              <li><strong><%= secret.inventory %></strong>: secretKey = <%= secret.secretKey %></li>
            <% }) %>
          </ul>

          <h3>t values from inventory randoms</h3>
          <ul>
            <% Object.entries(multiSig.tValues).forEach(([inv, tVal]) => { %>
              <li><strong><%= inv %></strong>: t = <%= tVal %></li>
            <% }) %>
          </ul>

          <h3>Request hash</h3>
          <p><strong>Record hash (SHA-256):</strong> <%= multiSig.partials[0].requestHash %></p>

          <form action="/query-record" method="POST">
            <input type="hidden" name="recordID" value="<%= recordId %>">
            <input type="hidden" name="stage" value="partials">
            <button type="submit">Step 2: Create partial signatures</button>
          </form>
        <% } else if (queryStage === 'partials') { %>
          <h2>Step 2: Inventory Partial Signatures</h2>
          <ul>
            <% multiSig.partials.forEach(part => { %>
              <li>
                <strong><%= part.inventory %></strong>: partialSignature = <%= part.partialSignature %>, valid = <%= part.valid %>
              </li>
            <% }) %>
          </ul>

          <form action="/query-record" method="POST">
            <input type="hidden" name="recordID" value="<%= recordId %>">
            <input type="hidden" name="stage" value="combine">
            <button type="submit">Step 3: Combine signatures</button>
          </form>
        <% } else if (queryStage === 'combine') { %>
          <h2>Step 3: Final Multi-Signature</h2>
          <p><strong>Combined multi-signature:</strong> <%= multiSig.combinedSignature %></p>
          <p><strong>Generated partial signatures:</strong> <%= multiSig.validSignaturesCount %> / 4</p>
          <p><strong>Consensus match count:</strong> <%= multiSig.consensus.count %> / 4</p>
          <p><strong>Consensus sources:</strong> <%= multiSig.consensus.sources.join(', ') %></p>

          <% if (multiSig.enough) { %>
            <p><strong>Verification passed.</strong> Displaying the majority record version.</p>
            <h3>Majority Record Version</h3>
            <p><strong>ItemID:</strong> <%= record.ItemID %></p>
            <p><strong>ItemQty:</strong> <%= record.ItemQty %></p>
            <p><strong>ItemPrice:</strong> <%= record.ItemPrice %></p>
            <p><strong>Location:</strong> <%= record.location %></p>
          <% } else { %>
            <p><strong>Access denied. Not enough matching copies to reach consensus.</strong></p>
          <% } %>
        <% } %>

        <a href="/">Back to Form</a>
      <% } %>
    <% } %>

    <% if (step === 'demo') { %>
      <h1>Record Submission</h1>

      <h2>Submitted Record:</h2>
      <p><strong>Origin Node (Proposer):</strong> <%= originNode %></p>
      <p><strong>ItemID:</strong> <%= record.ItemID %></p>
      <p><strong>ItemQty:</strong> <%= record.ItemQty %></p>
      <p><strong>ItemPrice:</strong> <%= record.ItemPrice %></p>
      <p><strong>Location:</strong> <%= record.location %></p>

      <h2>Steps:</h2>

      <h3>Step 1: Record Signed by Proposer</h3>
      <p>Inventory <%= originNode %> converts the record to a string, hashes it (SHA-256), then signs: <em>signature = hash<sup>d</sup> mod n</em></p>
      <p><strong>SHA-256 Hash:</strong> <%= hash %></p>
      <p><strong>Public Key:</strong> (e = <%= publicKey.e %>, n = <%= publicKey.n %>)</p>
      <p><strong>Private Key:</strong> (d = <%= privateKey.d %>, n = <%= privateKey.n %>)</p>
      <p><strong>Signature:</strong> <%= signature %></p>

      <h3>Step 2: Broadcast &amp; Verify at Each Inventory</h3>
      <p>The record and signature are sent to every inventory. Each one runs <em>sig<sup>e</sup> mod n == hash</em> before storing the record in its pending file.</p>
      <ul>
        <% broadcastResults.forEach(r => { %>
          <li>
            <strong>Inventory <%= r.inventory %>:</strong>
            <% if (r.accepted) { %>
              ACCEPTED — record stored in pending
            <% } else { %>
              REJECTED — signature invalid, record discarded
            <% } %>
          </li>
        <% }) %>
      </ul>

      <h3>Step 3: Consensus</h3>
      <p>Records are now in the pending files of all inventories that accepted them. Run consensus to check if at least 3/4 agree and commit.</p>
      <form action="/process-pending" method="POST">
        <input type="hidden" name="stage" value="compare">
        <button type="submit">Run Consensus</button>
      </form>

      <a href="/">Back to Form</a>
    <% } %>

    <% if (step === 'process') { %>
      <h1>Manual Consensus Workflow</h1>
      <p>This workflow is split into separate steps so you can follow the full PoA consensus process.</p>

      <% if (results.stage === 'compare') { %>
        <h2>Step 1: Compare Pending Records Across Inventories</h2>
        <p>Pending files contain only records that passed signature verification at broadcast time. Consensus requires at least 3 inventories to hold the same record.</p>

        <% if (results.candidates.length === 0) { %>
          <p>No pending records are available for comparison.</p>
        <% } else { %>
          <ul>
            <% results.candidates.forEach(candidate => { %>
              <li>
                <strong>Record:</strong> ItemID <%= candidate.record.ItemID %>, Qty <%= candidate.record.ItemQty %>, Price <%= candidate.record.ItemPrice %>, Location <%= candidate.record.location %><br>
                <strong>Matches:</strong> <%= candidate.count %> inventories (<%= candidate.sources.join(', ') %>)
              </li>
            <% }) %>
          </ul>
        <% } %>

        <p><strong><%= results.consensus.message %></strong></p>

        <% if (results.consensus.canCommit) { %>
          <form action="/process-pending" method="POST">
            <input type="hidden" name="stage" value="commit">
            <button type="submit">Step 2: Commit to All Inventories</button>
          </form>
        <% } else { %>
          <p>Consensus failed. Inventories will not be updated.</p>
        <% } %>
      <% } else if (results.stage === 'commit') { %>
        <h2>Step 2: Commit Record to Inventories</h2>
        <p><strong><%= results.consensus.message %></strong></p>

        <% if (results.consensus.status === 'passed') { %>
          <ul>
            <% results.consensus.passedRecords.forEach(rec => { %>
              <li>Committed record: ItemID <%= rec.record.ItemID %>, Qty <%= rec.record.ItemQty %>, Price: <%= rec.record.ItemPrice %>, Location: <%= rec.record.location %> (sources: <%= rec.sources.join(', ') %>)</li>
            <% }) %>
          </ul>
        <% } else { %>
          <p>No records were committed because consensus was not reached.</p>
        <% } %>
      <% } %>

      <a href="/">Back to Form</a>
    <% } %>

  </body>
</html>
